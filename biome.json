{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"files": {
		"ignoreUnknown": true
	},
	"linter": {
		"includes": [
			"apps/**/*.ts",
			"apps/**/*.vue",
			"apps/**/*.js",
			"apps/**/*.json"
		]
	},
	"formatter": {
		"includes": [
			"apps/**/*.ts",
			"apps/**/*.vue",
			"apps/**/*.js",
			"apps/**/*.json"
		]
	},
	"html": {
		"experimentalFullSupportEnabled": true
	}
}
